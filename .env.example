# TankCtl Backend Environment Configuration
# Copy this file to .env and update values for your environment

# MQTT Broker Configuration
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=tankctl
MQTT_PASSWORD=password

# PostgreSQL (Operational Database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tankctl
DB_USER=tankctl
DB_PASSWORD=password

# TimescaleDB (Telemetry Database)
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=tankctl_telemetry
TIMESCALE_USER=tankctl
TIMESCALE_PASSWORD=password

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Scheduler Configuration
SCHEDULER_ENABLED=true
DEVICE_OFFLINE_TIMEOUT=60
SHADOW_RECONCILIATION_INTERVAL=10
OFFLINE_DETECTION_INTERVAL=30

# Logging
LOG_LEVEL=INFO
